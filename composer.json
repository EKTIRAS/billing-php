{
    "name": "ektiras/billing-php",
    "description": "Official Laravel SDK for the EKTIR Billing API — issue Greek myDATA-compliant receipts, invoices and credit notes, manage products, track EU OSS sales, await PDFs and listen to document events.",
    "type": "library",
    "license": "MIT",
    "keywords": ["ektir", "billing", "mydata", "greek-invoice", "laravel", "sdk"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ektir\\Billing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ektir\\Billing\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ektir\\Billing\\EktirBillingServiceProvider"
            ],
            "aliases": {
                "EktirBilling": "Ektir\\Billing\\Facades\\EktirBilling"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
